{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "height": 26,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "cpu", "battery"],
  "clock": {
    "interval": 3,
    "format": "{:%A, %I:%M %p}",
    "tooltip": false
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "tooltip": false,
    "format-icons": {
      "1": "ï‰¨",
      "2": "َ°Œھ",
      "3": "ï”›",
      "4": "َ°ٹ ",
      "5": "َ°“‡"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "{capacity}% ï‡¦",
    "format-icons": {
      "charging": ["َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"],
      "default": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },
    "format-full": "{capacity}% َ°‚…",
    "interval": 3,
    "tooltip": false,
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "network": {
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
    "format": "{icon}",
    "format-wifi": "{essid} {icon}",
    "format-ethernet": "َ°€‚",
    "format-disconnected": "َ°¤®",
    "format-linked": "َ°¤¯",
    "format-disabled": "َ°¤®",
    "tooltip": false,
    "interval": 3
  },
  "cpu": {
    "interval": 3,
    "format": "{usage}% َ°چ›",
    "tooltip": false
  }
}
